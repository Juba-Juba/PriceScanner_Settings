<Application x:Class="PriceScanner.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:PriceScanner.Converters"
             StartupUri="Views/MainWindow.xaml">

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Themes/Colors.xaml"/>
                <ResourceDictionary Source="/Themes/Styles.xaml"/>
                <ResourceDictionary Source="/Themes/ControlTemplates.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Converters -->
            <converters:BoolToFlowDirectionConverter  x:Key="BoolToFlowDirectionConverter"/>
            <converters:NullToVisibilityConverter      x:Key="NullToVisibility"/>
            <converters:HexStringToColorConverter      x:Key="HexToColor"/>
            <converters:ExpiryStatusToBrushConverter   x:Key="ExpiryStatusToBrush"/>
            <converters:PercentageConverter            x:Key="PercentageConverter"/>
            <BooleanToVisibilityConverter              x:Key="BoolToVisibility"/>

        </ResourceDictionary>
    </Application.Resources>

</Application>
